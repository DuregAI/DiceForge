#Root {
    width: 100%;
    height: 100%;
    position: relative;
}

#Corners {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
}

#CornerBR {
    position: absolute;
    right: 24px;
    bottom: 24px;
    flex-direction: row;
    align-items: center;
}

.icon-button {
    width: 144px;
    height: 144px;
    padding: 0;
    margin: 0;
    background-color: transparent;
    background-size: auto 120px;
    background-repeat: no-repeat;
    background-position: center;
    border-width: 0;
    text-shadow: 0 3px 8px rgba(0, 0, 0, 0.35), 0 0 8px rgba(120, 255, 190, 0.18);
    transition-property: scale, box-shadow;
    transition-duration: 0.14s;
    transition-timing-function: ease-out;
}

.icon-button:hover {
    scale: 1.04;
    text-shadow: 0 0 18px rgba(120, 255, 190, 0.55), 0 4px 12px rgba(0, 0, 0, 0.35);
}

.icon-button:active {
    scale: 0.94;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.35), 0 0 6px rgba(120, 255, 190, 0.2);
}

.menu-button:hover {
    scale: 1.04;
    text-shadow: 0 0 18px rgba(120, 255, 190, 0.55), 0 4px 12px rgba(0, 0, 0, 0.35);
}

.menu-button:active {
    scale: 0.94;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.35), 0 0 6px rgba(120, 255, 190, 0.2);
}

.state-settings {
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/Icons/settings_icon_wrench_gear.png?fileID=2800000&guid=2ac5cb687a486e54f9c31c898e93233f&type=3#settings_icon_wrench_gear");
}

.state-back {
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/Icons/back_icon_alchemy.png?fileID=2800000&guid=4aa8bbad5b40c1c46ae45932e279894b&type=3#back_icon_alchemy");
}

#Center {
    position: absolute;
    left: 50%;
    top: 50%;
    translate: -50% -50%;
}

.df-theme Button {
    min-width: 520px;
    height: 110px;
    padding-left: 0;
    padding-right: 0;
    padding-top: 0;
    padding-bottom: 0;
    background-color: transparent;
    border-width: 0;
    background-image: url("project://database/Assets/_Project/07_Art/UI/Settings/Atlas/settings_atlas.png?fileID=1479138588&guid=f33f9627bb2eb5b499e34d24a5eec65e&type=3#button");
    background-repeat: no-repeat;
    background-position: center;
    background-size: 100% 100%;
    -unity-font: url("project://database/Assets/_Project/07_Art/Fonts/LuckiestGuy-Regular%20SDF.asset?fileID=11400000&guid=d5895c83018429343b0fab6c7f6ebcd5&type=2#LuckiestGuy-Regular SDF");
    font-size: 50px;
    color: rgb(243, 227, 176);
    unity-text-align: middle-center;
    text-shadow: 0 2px 0 rgba(40, 25, 10, 0.85);
    transition-property: scale, box-shadow;
    transition-duration: 0.14s;
    transition-timing-function: ease-out;
}

.panel-title {
    -unity-font: url("project://database/Assets/_Project/07_Art/Fonts/LuckiestGuy-Regular%20SDF.asset?fileID=11400000&guid=d5895c83018429343b0fab6c7f6ebcd5&type=2#LuckiestGuy-Regular SDF");
    font-size: 32px;
    -unity-font-style: bold;
}

.settings-window {
    width: 828px;
    max-width: 920px;
    height: 800px;
    max-height: 920px;
    padding: 32px 36px;
    flex-direction: column;
    align-items: stretch;
    background-image: url("project://database/Assets/_Project/07_Art/UI/Settings/Atlas/settings_atlas.png?fileID=-2018858640&guid=f33f9627bb2eb5b499e34d24a5eec65e&type=3#settings_bg");
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
}

.settings-label {
    font-size: 14px;
    -unity-font-style: bold;
}

.settings-block {
    flex-direction: column;
}

.settings-slider {
    height: 45px;
    width: 100%;
}

.settings-slider .unity-base-slider__tracker {
    height: 20px;
    background-image: url("project://database/Assets/_Project/07_Art/UI/Settings/Atlas/settings_atlas.png?fileID=-2032385572&guid=f33f9627bb2eb5b499e34d24a5eec65e&type=3#slider_bg");
    background-size: 100% 100%;
    background-repeat: no-repeat;
    background-position: center;
    background-color: transparent;
    border-width: 0;
    width: 100%;
}

.settings-slider .unity-base-slider__dragger {
    width: 32px;
    height: 32px;
    background-image: url("project://database/Assets/_Project/07_Art/UI/Settings/Atlas/settings_atlas.png?fileID=-21477623&guid=f33f9627bb2eb5b499e34d24a5eec65e&type=3#slider_thumb_inactive");
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    border-width: 0;
    background-color: transparent;
}

.settings-slider:hover .unity-base-slider__dragger,
.settings-slider:active .unity-base-slider__dragger,
.settings-slider:focus .unity-base-slider__dragger {
    background-image: url("project://database/Assets/_Project/07_Art/UI/Settings/Atlas/settings_atlas.png?fileID=1751022810&guid=f33f9627bb2eb5b499e34d24a5eec65e&type=3#slider_thumb_active");
}

.settings-about-row {
    margin-top: 12px;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
}

.about-text {
    flex-direction: row;
    align-items: center;
    flex-grow: 1;
}

.about-separator {
    opacity: 0.7;
}

.copy-log-wrapper {
    position: relative;
    align-items: center;
}

.copy-log-button {
    width: 40px;
    height: 40px;
    padding: 0;
    background-color: transparent;
    background-image: url("project://database/Assets/_Project/07_Art/UI/Settings/Atlas/settings_atlas.png?fileID=512409149&guid=f33f9627bb2eb5b499e34d24a5eec65e&type=3#copy_log");
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    border-width: 0;
}

.copy-log-tooltip {
    position: absolute;
    right: 0;
    bottom: 48px;
    width: 180px;
    height: 60px;
    background-image: url("project://database/Assets/_Project/07_Art/UI/Settings/Atlas/settings_atlas.png?fileID=-215124535&guid=f33f9627bb2eb5b499e34d24a5eec65e&type=3#log_tooltip");
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
}

.settings-overlay {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    justify-content: center;
    align-items: center;
    background-color: rgba(0, 0, 0, 0.35);
    opacity: 0;
    translate: 0 10px;
    transition-property: opacity, translate;
    transition-duration: 0.2s;
    transition-timing-function: ease-out;
}

.settings-overlay.is-visible {
    display: flex;
    opacity: 1;
    translate: 0 0;
}

.debug-red {
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: red;
    border-right-color: red;
    border-top-color: red;
    border-bottom-color: red;
}

.debug-blue {
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: deepskyblue;
    border-right-color: deepskyblue;
    border-top-color: deepskyblue;
    border-bottom-color: deepskyblue;
}

.settings-overlay {
    position: absolute;
}

.main-menu-button {
    text-shadow: 5px 5px 0 rgb(40, 25, 10);
    -unity-text-outline-width: 4px;
    -unity-font-style: bold;
    -unity-font-definition: url("project://database/Assets/_Project/07_Art/Fonts/LuckiestGuy-Regular.ttf?fileID=12800000&guid=3cf501bc73dc1144aa7910d77ab93b5f&type=3#LuckiestGuy-Regular");
    -unity-text-outline-color: rgb(68, 68, 68);
    -unity-text-align: middle-center;
    padding-top: 16px;
}

.wallet-panel {
    min-width: 0;
    padding: 2px 0 2px 0;
    background-color: transparent;
    border-radius: 0;
}

.wallet-section,
.wallet-actions {
    padding: 12px 14px;
    background-color: rgba(30, 22, 15, 0.18);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(236, 206, 144, 0.08);
    border-right-color: rgba(236, 206, 144, 0.08);
    border-top-color: rgba(255, 239, 202, 0.05);
    border-bottom-color: rgba(55, 36, 19, 0.12);
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
    border-bottom-left-radius: 16px;
    border-bottom-right-radius: 16px;
}

.wallet-section-xp,
.wallet-section-chest,
.wallet-actions {
    margin-top: 16px;
}

.wallet-actions {
    flex-direction: column;
    align-items: stretch;
}

.wallet-actions-title {
    margin-bottom: 10px;
    color: rgba(230, 213, 176, 0.82);
    font-size: 14px;
    -unity-font-style: bold;
    -unity-text-align: middle-left;
    text-shadow: 0 1px 0 rgba(56, 37, 16, 0.55);
}

.wallet-row {
    min-height: 54px;
    margin-bottom: 8px;
    padding-left: 2px;
    padding-right: 2px;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
}

.wallet-row-tight,
.wallet-row-feature-head {
    min-height: 50px;
    margin-bottom: 0;
}

.wallet-row-leading {
    flex-direction: row;
    align-items: center;
    flex-grow: 1;
    min-width: 0;
}

.wallet-row-icon {
    width: 46px;
    height: 46px;
    margin-right: 12px;
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
    flex-shrink: 0;
}

.wallet-row-icon-coins {
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_icon_coin.png?fileID=2800000&guid=6d4625b4184e42769e07d113ccb1e721&type=3#lp_icon_coin");
}

.wallet-row-icon-essence {
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_icon_essence.png?fileID=2800000&guid=a2d67885be1a4a79a6539fba5f84cc42&type=3#lp_icon_essence");
}

.wallet-row-icon-shards {
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_icon_shard.png?fileID=2800000&guid=d1d4a0d6eeac4c3da5b80a47253d5329&type=3#lp_icon_shard");
}

.wallet-row-icon-xp {
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_icon_xp.png?fileID=2800000&guid=f4fd677d98df4021a6f56fca634abb21&type=3#lp_icon_xp");
}

.wallet-row-icon-chest {
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/chest_shop_small.png?fileID=2800000&guid=cdd6ef72edd746478b260f70bc05ba62&type=3#chest_shop_small");
}

.wallet-row-title,
.wallet-row-inline-value,
.wallet-row-value,
.wallet-row-progress,
.wallet-chest-badge {
    color: rgb(247, 236, 204);
    -unity-font-style: bold;
    text-shadow: 0 2px 0 rgba(56, 37, 16, 0.85);
}

.wallet-row-title {
    font-size: 22px;
}

.wallet-row-inline-value {
    display: none;
}

.wallet-row-value,
.wallet-row-progress {
    min-width: 94px;
    font-size: 27px;
    -unity-text-align: middle-right;
}

.wallet-xp-bar {
    margin-top: 10px;
    padding-left: 4px;
    padding-right: 4px;
}

.wallet-xp-bar-track {
    height: 30px;
    padding: 4px;
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_progress_frame_9s.png?fileID=2800000&guid=a8c4c9982d8549788db0a9ccb7442ab1&type=3#lp_progress_frame_9s");
    background-repeat: no-repeat;
    background-size: 100% 100%;
    -unity-slice-left: 18;
    -unity-slice-right: 18;
    -unity-slice-top: 14;
    -unity-slice-bottom: 14;
}

.wallet-xp-fill {
    height: 100%;
    width: 0;
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_progress_fill.png?fileID=2800000&guid=9f6d5e6d234b4b8e9ab2c4f1383fa321&type=3#lp_progress_fill");
    background-repeat: no-repeat;
    background-size: 100% 100%;
    -unity-slice-left: 18;
    -unity-slice-right: 18;
    -unity-slice-top: 14;
    -unity-slice-bottom: 14;
}

.wallet-feature-card {
    padding: 12px 14px 14px 14px;
    background-color: rgba(22, 17, 12, 0.30);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(236, 206, 144, 0.08);
    border-right-color: rgba(236, 206, 144, 0.08);
    border-top-color: rgba(255, 239, 202, 0.05);
    border-bottom-color: rgba(55, 36, 19, 0.12);
    border-top-left-radius: 14px;
    border-top-right-radius: 14px;
    border-bottom-left-radius: 14px;
    border-bottom-right-radius: 14px;
}

.wallet-feature-card-chest {
    padding: 10px 10px 12px 10px;
}

.wallet-chest-button {
    position: relative;
    width: 100%;
    min-width: 0;
    height: 138px;
    min-height: 138px;
    padding: 0;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.02);
    background-image: none;
    border-width: 0;
    border-top-left-radius: 14px;
    border-top-right-radius: 14px;
    border-bottom-left-radius: 14px;
    border-bottom-right-radius: 14px;
    flex-shrink: 0;
    transition-property: scale, opacity;
    transition-duration: 0.12s;
    transition-timing-function: ease-out;
}

.wallet-chest-button:hover {
    scale: 1.015;
}

.wallet-chest-button:active {
    scale: 0.985;
}

.wallet-chest-button:disabled {
    opacity: 0.8;
}

.wallet-chest-badge {
    position: absolute;
    right: 8px;
    top: 6px;
    min-width: 48px;
    height: 48px;
    padding-left: 10px;
    padding-right: 10px;
    padding-top: 9px;
    color: rgb(255, 247, 220);
    font-size: 24px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    background-color: rgba(90, 61, 26, 0.96);
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgba(230, 196, 108, 0.92);
    border-right-color: rgba(230, 196, 108, 0.92);
    border-top-color: rgba(230, 196, 108, 0.92);
    border-bottom-color: rgba(230, 196, 108, 0.92);
    border-top-left-radius: 999px;
    border-top-right-radius: 999px;
    border-bottom-left-radius: 999px;
    border-bottom-right-radius: 999px;
}

.wallet-chest-art {
    width: 192px;
    min-width: 192px;
    height: 143px;
    min-height: 143px;
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_chest_cluster.png?fileID=2800000&guid=c153be46d5a54d0e8a12ea8bdb5cfb52&type=3#lp_chest_cluster");
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
    flex-shrink: 0;
}

.left-sidebar-button {
    height: 58px;
    padding-left: 22px;
    padding-right: 22px;
    background-color: transparent;
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_button_primary_9s.png?fileID=2800000&guid=b49f1657c9d54876a326fc5c5ad72fd1&type=3#lp_button_primary_9s");
    background-repeat: no-repeat;
    background-size: 100% 100%;
    border-width: 0;
    -unity-slice-left: 28;
    -unity-slice-right: 28;
    -unity-slice-top: 24;
    -unity-slice-bottom: 24;
    -unity-font: url("project://database/Assets/_Project/07_Art/Fonts/LuckiestGuy-Regular%20SDF.asset?fileID=11400000&guid=d5895c83018429343b0fab6c7f6ebcd5&type=2#LuckiestGuy-Regular SDF");
    font-size: 22px;
    color: rgb(247, 236, 204);
    -unity-text-align: middle-center;
    text-shadow: 0 3px 0 rgba(63, 41, 19, 0.85);
    transition-property: scale, opacity;
    transition-duration: 0.12s;
    transition-timing-function: ease-out;
}

.left-sidebar-button:hover {
    scale: 1.02;
}

.left-sidebar-button:active {
    scale: 0.98;
}

.left-sidebar-button:disabled {
    opacity: 0.55;
}

.left-sidebar-button-compact {
    width: 126px;
    height: 52px;
    font-size: 19px;
}

.left-sidebar-button-utility {
    height: 52px;
    font-size: 19px;
    opacity: 0.92;
}

.left-sidebar-button-secondary {
    margin-top: 0;
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_button_secondary_9s.png?fileID=2800000&guid=45ea0e62c4804e5e87712a9655ad8b30&type=3#lp_button_secondary_9s");
    color: rgb(193, 235, 132);
}


.left-sidebar-button-reset {
    margin-top: 8px;
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_button_secondary_9s.png?fileID=2800000&guid=45ea0e62c4804e5e87712a9655ad8b30&type=3#lp_button_secondary_9s");
    color: rgba(242, 231, 202, 0.92);
}

.wallet-result {
    display: none;
    margin-top: 10px;
    color: rgb(196, 237, 142);
    font-size: 13px;
    white-space: normal;
}
.upgrade-shop-window {
    position: relative;
    width: 940px;
    min-width: 940px;
    max-width: 940px;
    min-height: 760px;
    max-height: 860px;
    padding: 18px;
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_frame_9s.png?fileID=2800000&guid=d2458c1f2e9544f4b1f987e5a4019c11&type=3#lp_frame_9s");
    background-size: 100% 100%;
    background-repeat: no-repeat;
    -unity-slice-left: 48;
    -unity-slice-right: 48;
    -unity-slice-top: 48;
    -unity-slice-bottom: 48;
}

.upgrade-shop-content {
    flex-grow: 1;
    padding: 26px 28px 24px 28px;
    background-color: rgba(61, 45, 30, 0.96);
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_bg_tile.png?fileID=2800000&guid=7c92fe0db47d4cccb6511a4620e5d483&type=3#lp_bg_tile");
    background-repeat: repeat;
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
    border-bottom-left-radius: 20px;
    border-bottom-right-radius: 20px;
}

.upgrade-shop-header {
    margin-bottom: 14px;
}

.upgrade-shop-title {
    color: rgb(249, 239, 197);
    font-size: 40px;
    -unity-font-style: bold;
    -unity-text-align: middle-left;
    text-shadow: 0 3px 0 rgba(55, 34, 15, 0.82);
}

.upgrade-shop-subtitle {
    margin-top: 6px;
    color: rgb(223, 211, 180);
    font-size: 18px;
    white-space: normal;
}

.upgrade-shop-toolbar {
    margin-bottom: 14px;
    flex-direction: row;
    justify-content: flex-start;
}

.upgrade-shop-currency-pill {
    min-width: 188px;
    height: 54px;
    padding-left: 14px;
    padding-right: 18px;
    flex-direction: row;
    align-items: center;
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_header_plaque_9s.png?fileID=2800000&guid=5e82c84c7a9f4b3ab94b764bc8a9d321&type=3#lp_header_plaque_9s");
    background-size: 100% 100%;
    background-repeat: no-repeat;
    -unity-slice-left: 22;
    -unity-slice-right: 22;
    -unity-slice-top: 18;
    -unity-slice-bottom: 18;
}

.upgrade-shop-currency-icon {
    width: 32px;
    height: 32px;
    margin-right: 10px;
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_icon_coin.png?fileID=2800000&guid=6d4625b4184e42769e07d113ccb1e721&type=3#lp_icon_coin");
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
}

.upgrade-shop-coins {
    color: rgb(255, 231, 161);
    font-size: 28px;
    -unity-font-style: bold;
    text-shadow: 0 2px 0 rgba(55, 34, 15, 0.72);
}

.upgrade-list {
    flex-grow: 1;
    margin-bottom: 14px;
}

.upgrade-list .unity-scroll-view__content-container {
    padding-right: 8px;
}

.upgrade-card {
    min-height: 162px;
    margin-bottom: 14px;
    padding: 16px 18px;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    background-color: rgba(30, 22, 15, 0.76);
    background-image: url("project://database/Assets/_Project/07_Art/UI/MainMenu/lp_header_plaque_9s.png?fileID=2800000&guid=5e82c84c7a9f4b3ab94b764bc8a9d321&type=3#lp_header_plaque_9s");
    background-size: 100% 100%;
    background-repeat: no-repeat;
    -unity-slice-left: 22;
    -unity-slice-right: 22;
    -unity-slice-top: 18;
    -unity-slice-bottom: 18;
    border-left-width: 2px;
    border-right-width: 2px;
    border-top-width: 2px;
    border-bottom-width: 2px;
    border-left-color: rgba(227, 189, 109, 0.82);
    border-right-color: rgba(227, 189, 109, 0.82);
    border-top-color: rgba(227, 189, 109, 0.82);
    border-bottom-color: rgba(227, 189, 109, 0.82);
    border-top-left-radius: 18px;
    border-top-right-radius: 18px;
