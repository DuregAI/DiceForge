    -unity-font-style: bold;
    -unity-text-outline-width: 3px;
    -unity-text-outline-color: rgb(0, 0, 0);
    text-shadow: 4px 4px 0 rgb(0, 0, 0);
}

.feedback-dropdown {
    width: 100%;
    flex-grow: 0;
    min-height: 52px;
    height: 52px;
    max-height: 52px;
}

.feedback-dropdown .unity-base-field__input,
.feedback-dropdown .unity-popup-field__input,
.feedback-dropdown .unity-popup-field__text {
    color: rgb(248, 238, 196);
    background-color: rgba(24, 20, 15, 0.94);
    min-height: 48px;
    height: 48px;
    font-size: 20px;
    white-space: nowrap;
    -unity-text-align: middle-left;
    unity-text-align: middle-left;
}

.feedback-message-field .unity-base-text-field__input {
    font-size: 20px;
}












